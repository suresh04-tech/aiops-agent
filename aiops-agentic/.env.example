# ── Database ─────────────────────────────────────────────────────────────────
DB_HOST=your-rds-endpoint.ap-south-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_SSL_MODE=require          # use 'disable' for local Postgres

# ── AWS (used for Bedrock; per-incident AWS creds come from DB connector) ─────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# ── Bedrock model for the agent ───────────────────────────────────────────────
# Tool calling is supported by Claude 3 Sonnet and above.
# Haiku works but reasons less deeply. Avoid older models.
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0
# Other options:
#   anthropic.claude-3-5-sonnet-20241022-v2:0   (best, if available in region)
#   anthropic.claude-3-haiku-20240307-v1:0      (faster, less thorough)

# ── Agent tuning ──────────────────────────────────────────────────────────────
AGENT_MAX_ITERATIONS=30      # max agent turns (each turn = 1 LLM call)
MAX_COLLECTOR_WORKERS=10     # parallel EC2 instance collectors
